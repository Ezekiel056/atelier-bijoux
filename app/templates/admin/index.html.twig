{% extends 'admin/base.html.twig' %}

{% block title %}Panel admin{% endblock %}

{% block content %}
    <div class="max-w-4xl mx-auto p-6 flex flex-col gap-8">
        <div class="flex items-center justify-between">
            <h1 class="font-butterfly-kids text-3xl font-thin text-(--color-primary-dark)">Mes créations</h1>
            <a href="{{ path('app_admin_creation_new') }}" class="btn">Ajouter une création</a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="rounded-(--border-radius) border border-green-300 bg-green-50 px-3 py-2 text-sm text-green-700">
                {{ message }}
            </div>
        {% endfor %}

        <section class="flex flex-col gap-4">
            <h2 class="font-comic-neue font-bold text-xl text-(--color-primary-darker)">Actives</h2>

            {% if activeCreations is empty %}
                <p class="font-comic-neue text-sm text-(--color-primary-darker)">Aucune création active.</p>
            {% endif %}

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {% for creation in activeCreations %}
                    {% include 'admin/_creation_card.html.twig' %}
                {% endfor %}
            </div>
        </section>

        <section class="flex flex-col gap-4">
            <h2 class="font-comic-neue font-bold text-xl text-(--color-primary-darker)">Archivées</h2>

            {% if archivedCreations is empty %}
                <p class="font-comic-neue text-sm text-(--color-primary-darker)">Aucune création archivée.</p>
            {% endif %}

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {% for creation in archivedCreations %}
                    {% include 'admin/_creation_card.html.twig' %}
                {% endfor %}
            </div>
        </section>
    </div>
{% endblock %}