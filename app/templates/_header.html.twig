<header class="grid grid-cols-[64px_1fr_64px] py-6 px-4 mb-8 bg-white items-center relative" data-controller="menu">
    <div class="flex items-center justify-center">
        <img width="48px" height="48px" src={{ asset('/images/logo.png')}} alt="logo-boutique">
    </div>
    <h1 class="text-center font-butterfly-kids text-4xl font-thin md:hidden md:aria-hidden text-(--color-primary-dark) ">
        L'atelier bijoux
    </h1>
    <nav data-menu-target="nav" class="hidden md:flex flex-col md:flex-row absolute md:static top-full left-0 w-full md:w-auto bg-white md:bg-transparent p-6 md:p-0 gap-6 shadow-md md:shadow-none z-10 md:flex-1 md:justify-center text-2xl font-pacifico text-(--color-primary-darker)" aria-label="menu principal">
        <ul>
            <li>
                <a href={{ path('app_home') }} data-action="menu#close">Accueil</a>
            </li>
        </ul>
        <ul>
            <li>
                <a href={{ path('app_home') }} data-action="menu#close">A propos</a>
            </li>
        </ul>
        <ul>
            <li>
                <a href={{ path('app_home') }} data-action="menu#close">Mes créations</a>
            </li>
        </ul>
        <ul>
            <li>
                <a href="#contact" data-action="menu#close">Contact</a>
            </li>
        </ul>
        {% if app.user %}
            <ul>
                <li>
                    <a href={{ path('app_admin_login') }} data-action="menu#close">Admin</a>
                </li>
            </ul>
        {% endif %}
    </nav>
    <div class="flex items-center justify-center md:hidden">
        <button type="button" data-menu-target="button" data-action="menu#toggle" aria-label="Menu" aria-expanded="false" class="flex flex-col justify-center gap-1.5  h-6 cursor-pointer w-8">
            <span class="block h-1 w-full bg-(--color-primary-dark)"></span>
            <span class="block h-1 w-full bg-(--color-primary-dark)"></span>
            <span class="block h-1 w-full bg-(--color-primary-dark)"></span>
        </button>
    </div>
</header>
